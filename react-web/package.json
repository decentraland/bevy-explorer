{
  "name": "bevy-ui-react-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "React DOM port of the bevy-ui-scene HUD. Hosts the engine in a same-origin iframe and drives it over a super-user bridge scene. Does NOT affect the production SDK7 scene in ../scene.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
